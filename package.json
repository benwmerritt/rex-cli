{
  "name": "@benmerritt/rex-cli",
  "version": "0.1.0",
  "description": "Retail Express POS CLI for agentic workflows — read and (carefully) write the Retail Express catalogue from the command line.",
  "type": "module",
  "bin": {
    "rex": "./dist/rex.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run src/rex.ts",
    "build": "bun build src/rex.ts --outfile dist/rex.js --target node",
    "compile": "bun build src/rex.ts --compile --outfile rex",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "docs": "bun run scripts/generate-docs.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "smol-toml": "^1.3.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "author": "Ben Merritt",
  "repository": {
    "type": "git",
    "url": "https://github.com/benwmerritt/rex-cli.git"
  },
  "keywords": [
    "retail-express",
    "maropost",
    "pos",
    "cli",
    "agent",
    "agentic"
  ]
}
